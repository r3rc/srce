{
    "name": "@r3rc/srce",
    "version": "0.1.0",
    "license": "MIT",
    "author": "Renzo A. Rosas <renzo.r3rc@gmail.com> (https://r3rc.dev)",
    "homepage": "https://r3rc.dev",
    "repository": "https://github.com/r3rc/srce",
    "exports": "./src/mod.ts",
    "tasks": {
        "tinker": "deno run -A jsr:@r3rc/tinker/cli"
    },
    "imports": {
        "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
        "@h3js/h3": "npm:h3@2.0.1-rc.21",
        "@h3js/srvx": "npm:srvx@0.11.15",
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "@std/encoding": "jsr:@std/encoding@^1.0.10",
        "@std/path": "jsr:@std/path@^1.1.4",
        "@std/semver": "jsr:@std/semver@^1.0.8",
        "@std/tar": "jsr:@std/tar@^0.1.10",
        "@unjs/citty": "npm:citty@0.2.2",
        "@valibot/valibot": "jsr:@valibot/valibot@^1.3.1"
    },
    "compilerOptions": {
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true
    },
    "fmt": {
        "exclude": [".tinker/", ".claude/"],
        "lineWidth": 120,
        "indentWidth": 4,
        "trailingCommas": "never"
    },
    "lint": {
        "rules": {
            "tags": ["recommended"],
            "include": ["eqeqeq", "no-throw-literal", "no-sync-fn-in-async-fn"]
        },
        "exclude": [".tinker/"]
    },
    "test": {
        "exclude": [".tinker/"]
    }
}
